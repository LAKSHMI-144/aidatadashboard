{
  "version": 2,
  "buildCommand": "cd ai-dashboard && npm run build",
  "outputDirectory": "ai-dashboard/build",
  "installCommand": "cd ai-dashboard && npm install",
  "framework": null,
  "builds": [
    {
      "src": "ai-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
